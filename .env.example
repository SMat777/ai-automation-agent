# AI Automation Agent – Environment Variables
#
# Copy this file to `.env` and fill in the values you need.
# All variables are optional for local development — sensible defaults
# are applied in app/config.py.

# ─── Database ─────────────────────────────────────────────────────────────
# Default: SQLite file in the repo root (./app.db). No setup required.
# For production: set DATABASE_URL to your Postgres connection string, e.g.
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./app.db

# ─── Anthropic API ────────────────────────────────────────────────────────
# Get your key from: https://console.anthropic.com/
# Without this, the app runs in demo mode (pre-written agent responses, and
# extractive summarization instead of AI-generated summaries).
ANTHROPIC_API_KEY=

# Model selection — rarely needs to change.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Logging ──────────────────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
